# Mielesy Platform — Complete Environment Variables
# Sourced from: Master Blueprint v2.0 + archive pasted_content_3.txt

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://mielesy.com"
NODE_ENV="development"

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/mielesy"
REDIS_URL="redis://..."

# ── Clerk (Authentication) ────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_CLIENT_ID=""  # for event host payouts via Stripe Connect

# Membership price IDs (create in Stripe dashboard)
STRIPE_PRICE_MEMBER=""      # $9.99/mo or $29/mo — TBD
STRIPE_PRICE_VIP=""         # $29.99/mo or $79/mo — TBD

# Credit package price IDs
STRIPE_PRICE_CREDITS_100=""
STRIPE_PRICE_CREDITS_500=""

# ── Print-on-Demand (Phase 5, legal review required first) ────────────────────
PRINTFUL_API_KEY=""
PRINTIFY_API_KEY=""

# ── Email ────────────────────────────────────────────────────────────────────
# Archive used SendGrid; blueprint uses Resend. Using Resend.
